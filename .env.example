# ============================================================
# Competitive Intelligence Briefing Crew - Environment Config
# ============================================================
# Copy this file to .env and fill in your real values

# LLM Provider (required - use one of the following)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Groq (fast, free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Search (optional - falls back to DuckDuckGo if not set)
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith tracing (optional)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=competitive-intelligence-crew

# Model selection
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# App
APP_ENV=development
LOG_LEVEL=INFO
REQUEST_TIMEOUT=60

# Workflow limits
MAX_SEARCH_RESULTS=10
MAX_WORKFLOW_STEPS=20
MAX_RETRIES=3

# RAG
RAG_ENABLED=true
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
VECTOR_STORE=faiss
